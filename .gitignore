/data/real/**/raw/
/data/real/**/processed/
*.npy

# Generated report figures are reproducible from scripts; keep small CSV summaries only
/docs/generated_figures/*.png
/docs/generated_figures/*.pdf
/docs/generated_figures/*.svg

# Local profiling/debug captures
/importtime_*.txt

# Generic generated outputs (any depth)
**/output/
**/outputs/
**/result/
**/results/
**/log/
**/logs/
**/figure/
**/figures/
**/table/
**/tables/
**/artifact/
**/artifacts/
**/run/
**/runs/
**/checkpoint/
**/checkpoints/
**/cache/
**/caches/

# Generated files
*.log
*.out
*.err

# Node dependencies
node_modules/

# Ordinary experiment outputs are local-only and should not be pushed.

# Local reference/vendor trees: keep in workspace, do not push
/gigg-master/
/gigg/
/rstanarm-master/

# Local CmdStan installs: keep in workspace, do not push
/.local_cmdstan/
/cmdstan/
/cmdstan-*/
